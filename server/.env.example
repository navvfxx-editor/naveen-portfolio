# Postgres connection string — Render gives you this when you create a
# PostgreSQL database (Render dashboard -> your DB -> "Internal Database URL"
# for the web service, or "External Database URL" for running locally).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Long random string used to sign login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# The ONE account allowed to log into /admin on the frontend.
OWNER_EMAIL=navv.fxx@gmail.com
OWNER_PASSWORD=choose_a_strong_password

# Your deployed frontend URL (Netlify), used for CORS. Add http://localhost:5173
# too during local development (comma-separated).
FRONTEND_URL=http://localhost:5173

# Public base URL of THIS backend once deployed on Render, e.g.
# https://naveen-portfolio-api.onrender.com — used to build file URLs.
PUBLIC_URL=http://localhost:4000

PORT=4000
